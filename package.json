{
  "name": "extopr-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css}\"",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=cms/payload.config.ts payload",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=cms/payload.config.ts payload generate:types",
    "generate:importmap": "cross-env PAYLOAD_CONFIG_PATH=cms/payload.config.ts payload generate:importmap",
    "db:push": "cross-env PAYLOAD_CONFIG_PATH=cms/payload.config.ts tsx scripts/push-schema.ts",
    "db:seed": "cross-env PAYLOAD_CONFIG_PATH=cms/payload.config.ts tsx scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.37.0",
    "@payloadcms/next": "^3.37.0",
    "@payloadcms/richtext-lexical": "^3.37.0",
    "@payloadcms/ui": "^3.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.9.0",
    "lucide-react": "^0.456.0",
    "next": "15.4.11",
    "payload": "^3.37.0",
    "react": "19.1.8",
    "react-dom": "19.1.8",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.4.11",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
